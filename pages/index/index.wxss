.page {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.title {
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.hint {
  color: #666;
  font-size: 24rpx;
  line-height: 1.5;
  display: block;
}

.meta {
  color: #0a7ea4;
  font-size: 24rpx;
  display: block;
  margin-top: 10rpx;
}

.field {
  margin-top: 20rpx;
}

.field-label {
  display: block;
  color: #666;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.input {
  height: 72rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 10rpx;
  padding: 0 20rpx;
  background: #fafafa;
}

.adaptive-gear {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #ff6b35;
  margin-bottom: 12rpx;
}

.reason-list {
  margin-top: 16rpx;
}

.reason {
  display: block;
  color: #666;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.label {
  color: #666;
  font-size: 24rpx;
  display: block;
  margin-bottom: 12rpx;
}

.hex {
  font-family: monospace;
  font-size: 22rpx;
  word-break: break-all;
  display: block;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.compact-actions {
  margin-bottom: 0;
}

.btn {
  margin-top: 16rpx;
}

.mini-btn {
  min-width: 140rpx;
}

.segmented {
  display: flex;
  border: 1rpx solid #d9d9d9;
  border-radius: 12rpx;
  overflow: hidden;
  margin-top: 20rpx;
}

.segment {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  background: #fff;
  color: #666;
}

.segment-active {
  background: #0a7ea4;
  color: #fff;
  font-weight: 600;
}

.device {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.device:last-child {
  border-bottom: none;
}

.device-info {
  flex: 1;
  padding-right: 16rpx;
}

.device-name {
  display: block;
  font-weight: 600;
}

.device-id {
  display: block;
  color: #999;
  font-size: 22rpx;
  margin-top: 8rpx;
  word-break: break-all;
}

.service {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.service:last-child {
  border-bottom: none;
}

.service-id {
  display: block;
  font-family: monospace;
  font-size: 22rpx;
  word-break: break-all;
}

.characteristic {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #fafafa;
}

.characteristic-id {
  display: block;
  font-family: monospace;
  font-size: 22rpx;
  word-break: break-all;
}

.gap-top {
  margin-top: 20rpx;
}
