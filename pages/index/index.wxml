<view class="page">
  <view class="card">
    <text class="title">暖绒加热 MVP</text>
    <text class="hint">当前先打通天气、微信运动接入占位和初步自适应决策。BLE 写入保留在页面下半部分，便于后续联调。</text>
  </view>

  <view class="card">
    <text class="label">天气</text>
    <text class="meta">天气：{{weatherText}}</text>
    <text class="meta">室外温度：{{outdoorTemp}}°C</text>
    <text class="meta">体感温度：{{feelsLikeTemp}}°C</text>
    <text class="meta">来源：{{weatherSource === 'live' ? '实时' : '模拟'}}</text>
    <text class="meta" wx:if="{{weatherObservationTime}}">观测时间：{{weatherObservationTime}}</text>
    <button class="btn" type="primary" bindtap="onFetchWeather" loading="{{weatherLoading}}">获取天气</button>
  </view>

  <view class="card">
    <text class="label">微信运动</text>
    <text class="meta">获取状态：{{weRunStatus}}</text>
    <text class="meta">解密服务：{{weRunServerConfigured ? '已配置' : '未配置'}}</text>
    <text class="meta">服务健康：{{weRunServerHealthText}}</text>
    <text class="meta">解密链路：{{weRunServerConfigured ? '已接服务端解密' : (weRunEncryptedReady ? '已拿到加密数据，待服务端解密' : '未获取')}}</text>
    <text class="meta" wx:if="{{weRunCloudId}}">cloudID：{{weRunCloudId}}</text>
    <text class="meta" wx:if="{{weRunLastStep}}">最近步数：{{weRunLastStep}}</text>
    <view class="field">
      <text class="field-label">MVP 步数输入</text>
      <input class="input" type="number" value="{{stepCount}}" bindinput="onStepInput" placeholder="输入今日步数" />
    </view>
    <text class="meta">当前用于自适应的步数：{{stepCount}}（{{stepSource === 'manual' ? '手动' : '微信运动'}}）</text>
    <button class="btn" wx:if="{{weRunServerConfigured}}" bindtap="checkWeRunServerHealth">检查解密服务</button>
    <button class="btn" bindtap="onFetchWeRun">{{weRunServerConfigured ? '获取并解密微信运动' : '获取微信运动加密数据'}}</button>
  </view>

  <view class="card">
    <text class="label">初步自适应建议</text>
    <text class="adaptive-gear">{{adaptiveGearText}}</text>
    <text class="meta">温度分层：{{adaptiveTempBand}}</text>
    <text class="meta">活动分层：{{adaptiveActivityBand}}</text>
    <text class="hint">{{adaptiveSummary}}</text>
    <view class="reason-list">
      <text class="reason" wx:for="{{adaptiveReasons}}" wx:key="*this">{{item}}</text>
    </view>
    <button class="btn" type="primary" bindtap="onApplyAdaptiveNow">切回自动模式并按建议预览</button>
  </view>

  <view class="card">
    <text class="label">控制模式</text>
    <view class="segmented">
      <view
        class="segment {{controlMode === 'auto' ? 'segment-active' : ''}}"
        data-mode="auto"
        bindtap="onSwitchMode"
      >
        自动
      </view>
      <view
        class="segment {{controlMode === 'manual' ? 'segment-active' : ''}}"
        data-mode="manual"
        bindtap="onSwitchMode"
      >
        手动
      </view>
    </view>
    <text class="meta">当前模式：{{controlMode === 'auto' ? '自动跟随建议' : '手动指定档位'}}</text>
    <text class="hint">{{controlModeSummary}}</text>
    <text class="meta">当前档位：{{currentGearText}}</text>
    <view class="field" wx:if="{{controlMode === 'manual'}}">
      <text class="field-label">手动档位</text>
      <view class="actions compact-actions">
        <button class="btn mini-btn" data-gear="0" bindtap="onSelectManualGear">关闭</button>
        <button class="btn mini-btn" data-gear="1" bindtap="onSelectManualGear">低档</button>
        <button class="btn mini-btn" data-gear="2" bindtap="onSelectManualGear">中档</button>
        <button class="btn mini-btn" data-gear="3" bindtap="onSelectManualGear">高档</button>
      </view>
      <text class="meta">已选择：{{manualGearText}}</text>
    </view>
  </view>

  <view class="card">
    <text class="label">当前控制指令预览</text>
    <text class="meta">{{packetReadyText}}</text>
    <view class="segmented">
      <view
        class="segment {{bleLengthMode === 'single_byte' ? 'segment-active' : ''}}"
        data-mode="single_byte"
        bindtap="onLengthModeChange"
      >
        单字节长度
      </view>
      <view
        class="segment {{bleLengthMode === 'double_byte' ? 'segment-active' : ''}}"
        data-mode="double_byte"
        bindtap="onLengthModeChange"
      >
        双字节长度
      </view>
    </view>
    <text class="hex" selectable="true">{{pendingPacketHex || '暂无'}}</text>
    <button class="btn" type="primary" data-use-current="1" bindtap="onSendGear">发送当前档位指令</button>
  </view>

  <view class="card">
    <text class="label">BLE 状态</text>
    <text class="meta">状态：{{statusText}}</text>
    <text class="meta" wx:if="{{connected}}">设备：{{connectedDeviceName}}</text>
  </view>

  <view class="card">
    <text class="label">BLE 合同确认</text>
    <text class="meta">状态：{{bleContractStatus}}</text>
    <text class="meta">来源：{{bleContractSource}}</text>
    <text class="meta">首选广播前缀：{{bleNamePrefix || '未限制'}}</text>
    <text class="hex" selectable="true">Preferred Service: {{blePreferredServiceId || '未配置'}}</text>
    <text class="hex" selectable="true">Preferred Notify: {{blePreferredNotifyCharacteristicId || '未配置'}}</text>
    <text class="hex" selectable="true">Preferred Write: {{blePreferredWriteCharacteristicId || '未配置'}}</text>
    <text class="hex" selectable="true">Active Write Service: {{bleActiveWriteServiceId || '待连接后自动探测'}}</text>
    <text class="hex" selectable="true">Active Notify Service: {{bleActiveNotifyServiceId || '待连接后自动探测'}}</text>
    <text class="hex" selectable="true">Active Notify: {{bleActiveNotifyCharacteristicId || '未发现'}}</text>
    <text class="hex" selectable="true">Active Write: {{bleActiveWriteCharacteristicId || '未发现'}}</text>
    <text class="meta">写入属性：{{bleWritePropertyText}}</text>
    <text class="meta">通知属性：{{bleNotifyPropertyText}}</text>
  </view>

  <view class="card" wx:if="{{bleServices.length}}">
    <text class="label">已发现服务与特征</text>
    <view class="service" wx:for="{{bleServices}}" wx:key="serviceId" wx:for-item="service">
      <text class="service-id">{{service.serviceId}}</text>
      <text class="meta">{{service.summary}}</text>
      <view class="characteristic" wx:for="{{service.characteristics}}" wx:key="uuid" wx:for-item="charItem">
        <text class="characteristic-id">{{charItem.uuid}}</text>
        <text class="meta">{{charItem.propsText}}</text>
        <text class="meta" wx:if="{{charItem.roleText}}">用途：{{charItem.roleText}}</text>
      </view>
    </view>
  </view>

  <view class="actions">
    <button class="btn" type="primary" bindtap="onStartScan" loading="{{scanning}}">开始扫描</button>
    <button class="btn" bindtap="onStopScan">停止扫描</button>
    <button class="btn" bindtap="onDisconnect" disabled="{{!connected}}">断开连接</button>
  </view>

  <view class="card" wx:if="{{devices.length}}">
    <text class="label">发现设备</text>
    <view class="device" wx:for="{{devices}}" wx:key="deviceId">
      <view class="device-info">
        <text class="device-name">{{item.name}}</text>
        <text class="device-id">{{item.deviceId}}</text>
      </view>
      <button
        size="mini"
        type="primary"
        data-deviceid="{{item.deviceId}}"
        data-name="{{item.name}}"
        bindtap="onConnectDevice"
      >
        连接
      </button>
    </view>
  </view>

  <view class="card">
    <text class="label">左袜控制（SOCK_L）</text>
    <view class="actions">
      <button class="btn" data-gear="0" bindtap="onSendGear">关闭</button>
      <button class="btn" data-gear="1" bindtap="onSendGear">低档</button>
      <button class="btn" data-gear="2" bindtap="onSendGear">中档</button>
      <button class="btn" data-gear="3" bindtap="onSendGear">高档</button>
    </view>
  </view>

  <view class="card">
    <text class="label">示例包（与文档 AA0E01010101030200280401E00D）</text>
    <text class="hex" selectable="true">{{exampleHex}}</text>
  </view>

  <view class="card">
    <text class="label">最近发送 HEX</text>
    <text class="hex" selectable="true">{{lastSentHex || '暂无'}}</text>
    <text class="label gap-top">最近接收 HEX</text>
    <text class="hex" selectable="true">{{lastReceivedHex || '暂无'}}</text>
    <text class="label gap-top">最近接收解析</text>
    <text class="hint">{{lastReceivedPacketText}}</text>
    <text class="meta">设备上报档位：{{deviceReportedGearText}}</text>
    <text class="meta">设备上报电源：{{deviceReportedPowerText}}</text>
    <text class="meta">设备上报电池：{{deviceReportedBatteryText}}</text>
  </view>

  <button class="btn" type="primary" bindtap="onCopyExample">复制示例 HEX</button>
</view>
